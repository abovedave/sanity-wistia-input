{
  "name": "sanity-plugin-wistia-input",
  "version": "4.0.0",
  "description": "Wistia input for Sanity v5",
  "repository": {
    "type": "git",
    "url": "https://github.com/abovedave/sanity-wistia-input.git"
  },
  "keywords": [
    "sanity",
    "sanity-plugin",
    "wistia"
  ],
  "license": "MIT",
  "author": "David Longworth <djl.fyi@sent.com>",
  "browserslist": "extends @sanity/browserslist-config",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "commonjs",
  "files": [
    "dist",
    "sanity.json",
    "src",
    "v2-incompatible.js"
  ],
  "scripts": {
    "build": "plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
    "clean": "rimraf dist",
    "format": "prettier --write --cache --ignore-unknown .",
    "link-watch": "plugin-kit link-watch",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "watch": "pkg-utils watch --strict"
  },
  "dependencies": {
    "@sanity/icons": "^3.7.4",
    "@sanity/incompatible-plugin": "^1.0.5",
    "@sanity/ui": "^3.1.11",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@sanity/pkg-utils": "^10.4.11",
    "@sanity/plugin-kit": "^4.0.20",
    "@types/react": "^19",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-sanity": "^7.1.4",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.3",
    "prettier-plugin-packagejson": "^2.5.20",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.0",
    "rimraf": "^6.1.2",
    "sanity": "^5.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^18.3 || ^19",
    "react-dom": "^18.3 || ^19",
    "sanity": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@rollup/plugin-alias": "^5.1.1"
  },
  "sanityPlugin": {
    "verifyPackage": {
      "eslintImports": false
    },
    "linkWatch": {
      "extensions": "ts,tsx,js,png,svg,gif,jpeg,css"
    }
  }
}
